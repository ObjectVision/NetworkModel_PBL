		attribute<string>       Mode            := Elements/Text[value(UInt32(ID(.))* nrAttr + 0, Elements)];
		attribute<string>       Vervoerder      := Elements/Text[value(UInt32(ID(.))* nrAttr + 1, Elements)], Descr = "/SourceData/Infrastructure/GTFS/LoadFeeds/ReadFSS/agency/Data/agency_name";
		attribute<string>       Concessiegebied := Elements/Text[value(UInt32(ID(.))* nrAttr + 3, Elements)];
		attribute<string>       Lijn            := Elements/Text[value(UInt32(ID(.))* nrAttr + 4, Elements)];
		attribute<Euro>         FixedPrice      := Elements/Text[value(UInt32(ID(.))* nrAttr + 5, Elements)][Euro];
		attribute<Euro_km>      VariablePrice   := Elements/Text[value(UInt32(ID(.))* nrAttr + 6, Elements)][Euro_km];
		attribute<string>       Opmerking       := Elements/Text[value(UInt32(ID(.))* nrAttr + 7, Elements)];
		
		attribute<Modes>             Mode_rel               := rlookup(Mode, Modes/name);
		attribute<Agencies>          Agency_rel             := rlookup(lowercase(Vervoerder), Agencies/name);
		attribute<Concessiegebieden> Concessiegebieden_rel  := rlookup(AsItemName(Concessiegebied), Concessiegebieden/name);
		
		attribute<string>       Concessiegebied_str := AsItemName(Concessiegebied != '' ? ''+Concessiegebied : '');
		attribute<string>       Lijn_str            := Lijn != '' ? '_'+Lijn : '';
		
		attribute<string>       Mode_Agency_CG_Lijn_identifier := Mode +'_'+ lowercase(Vervoerder) +'_'+ Concessiegebied_str + Lijn_str;
		attribute<string>       Mode_Agency_CG_identifier      := Mode +'_'+ lowercase(Vervoerder) +'_'+ Concessiegebied_str;
		attribute<string>       Mode_Agency_identifier         := Mode +'_'+ lowercase(Vervoerder);
		attribute<string>       label                          := Mode_Agency_CG_Lijn_identifier;

		parameter<uint32> nrAttr := 8;
	}

	container NS
	{
		unit<uint32> NS_PricePerTariffUnit
		: StorageName = "='%ProjDir%/Data/Tarieven_NS/NS tarieven '+ModelParameters/Advanced/NS_prijzen_year+'.csv'"
		, StorageType = "gdal.vect"
		, StorageReadOnly = "true"
		, URL = "https://www.ns.nl/binaries/_ht_1704966727326/content/assets/ns-nl/tarieven/2024/consumenten/ns-tarievenlijst-consumenten-2024.pdf"
		, Descr = "uit pdf tabel kopieren naar csv en editten naar gewenst format."
		{
			attribute<uint32>  TariffUnits      := uint32(Aantal_tarief_eenheden);
			attribute<float32> Delta_FullFare   := FullFare - MakeDefined(FullFare[sub_or_null(id(.), 1)], 0f);
			attribute<euro>    FullFare         := float32(Voltarief_incl_9_btw)[euro];
			attribute<euro>    Discount_20pct   := float32(_20_korting_incl_9_btw)[euro];
			attribute<euro>    Discount_40pct   := float32(_40_korting_incl_9_btw)[euro];
		}
				
		unit<uint32> NS_TariffUnits_matrix
		: StorageName = "%ProjDir%/Data/Tarieven_NS/NS_tariefnet.csv"
		, StorageType = "gdal.vect"
		, StorageReadOnly = "true"
		, URL = "https://data.ndovloket.nl/ns/ns-latest.zip"
		, Descr = "tariefnet.dat downloaden, csv van maken, en headers toevoegen."
		{
			attribute<NS_stations> StartPoint_rel := rlookup(org, NS_stations/code);
			attribute<NS_stations> EndPoint_rel   := rlookup(dest, NS_stations/code);
			attribute<rdc>         StartPoint     := NS_stations/geometry[StartPoint_rel];
			attribute<rdc>         EndPoint       := NS_stations/geometry[EndPoint_rel];
			attribute<uint32>      TariffUnit     := uint32(unit2);
			attribute<rdc>         geometry (arc) := points2sequence(LinkPoints/Point, LinkPoints/Sequence_rel, LinkPoints/Ordinal);

			attribute<uint32> c_NS_start_end_rel := combine_data(c_NS_start_end, StartPoint_rel, EndPoint_rel);
			
			unit<uint32> c_NS_start_end := combine(NS_stations, NS_stations)
			{
				attribute<string> label         := NS_stations/code[first_rel] + '_' + NS_stations/code[second_rel];
				attribute<uint32> TariffUnit := rjoin(id(.), c_NS_start_end_rel, NS_TariffUnits_matrix/TariffUnit);
			}

			unit<uint32> OrgDest := select_with_org_rel(IsDefined(rlookup(NS_stations/geometry, StartPoint)) || IsDefined(rlookup(NS_stations/geometry, EndPoint)))
			{
				attribute<rdc>    geometry := NS_stations/geometry[org_rel];
				attribute<string> label    := NS_stations/label[org_rel];
			}
			
			unit<uint32> LinkPoints := union_unit(., .)
			{
				attribute<rdc>                  Point        := union_data(., StartPoint, EndPoint);
				attribute<..>                   Sequence_rel := union_data(., id(..), id(..));
				attribute<uint32>               Ordinal      := union_data(., const(0,..,uint32), const(1,..,uint32));
			}
			
			unit<uint32> ConnectedNetwork := select_with_attr_by_cond(., IsDefined(StartPoint) && IsDefined(EndPoint))
			{
				unit<uint32> NodeSet := unique(LinkPoints/Point)
				{
					attribute<rdc>    geometry := values;
					attribute<string> label    := rjoin(geometry, NS_stations/geometry, NS_stations/label);
					
				}
				
				attribute<NodeSet>  F1                  := rlookup(StartPoint,NodeSet/geometry);
				attribute<NodeSet>  F2                  := rlookup(EndPoint,NodeSet/geometry);
			
				attribute<NodeSet>  org_node (OrgDest)  := rlookup(OrgDest/geometry, NodeSet/geometry);
				attribute<NodeSet>  dst_node (OrgDest)  := rlookup(OrgDest/geometry, NodeSet/geometry);
			
			} 
			
			unit<uint32> ODMatrix :=
				impedance_matrix('bidirectional;startPoint(Node_rel);endPoint(Node_rel);od:impedance,OrgZone_rel,DstZone_rel,LinkSet'
					, ConnectedNetwork/TariffUnit
					, ConnectedNetwork/F1
					, ConnectedNetwork/F2
					
					, ConnectedNetwork/org_node
					, ConnectedNetwork/dst_node
				)
			{
				attribute<Euro> Price_FullFare   := impedance >= 200 
														? max(NS_PricePerTariffUnit/FullFare) 
														: rjoin(impedance, NS_PricePerTariffUnit/TariffUnits, NS_PricePerTariffUnit/FullFare);
				attribute<Euro> Price_20pct_Discount := impedance >= 200 
														? max(NS_PricePerTariffUnit/Price_20pct_Discount) 
														: rjoin(impedance, NS_PricePerTariffUnit/TariffUnits, NS_PricePerTariffUnit/Price_20pct_Discount);
				attribute<Euro> Price_40pct_Discount := impedance >= 200 
														? max(NS_PricePerTariffUnit/Price_40pct_Discount) 
														: rjoin(impedance, NS_PricePerTariffUnit/TariffUnits, NS_PricePerTariffUnit/Price_40pct_Discount);
				attribute<Euro> Prijs             := =ModelParameters/Advanced/NS_TariffChoice;
				attribute<Ct>   Prijs_ct          := rounded_convert(Prijs, Ct);
				attribute<NS_stations> Org_NS_station_rel  := OrgDest/org_rel[OrgZone_rel];
				attribute<NS_stations> Dest_NS_station_rel := OrgDest/org_rel[DstZone_rel];
				attribute<uint32>      c_NS_start_end_rel  := combine_data(c_NS_start_end, Org_NS_station_rel, Dest_NS_station_rel);
				
				// unit<uint32> TravelledJourney := sequence2points(LinkSet) //vertaling van LinkSet attribute (afgelegde route in OD), naar onderdelen van de reis
				// {
					// unit<uint32> LinkSet := ConnectedNetwork;
					// unit<uint32> NodeSet := ConnectedNetwork/NodeSet;

					// voor visuaisatie
					// attribute<rdc>         Route (arc) := points2sequence(LinkPoints/Point, LinkPoints/Sequence_rel, LinkPoints/Ordinal);
					// attribute<rdc>         FromPoint   := LinkSet/StartPoint[point];
					// attribute<rdc>         ToPoint     := LinkSet/EndPoint[point];
					
					// attribute<string>      orgname     := rjoin(LinkSet/org[point], NS_stations/code, NS_stations/label);
					// attribute<string>      label       := LinkSet/org[point] +'_'+ LinkSet/dest[point];


					// unit<uint32> sub := select_with_attr_by_cond(., orgname == 'Groningen')
					// {
					
					// }
	
					// unit<uint32> LinkPoints := union_unit(., .)
					// {
						// attribute<rdc>                  Point        := union_data(., FromPoint, ToPoint);
						// attribute<..>                   Sequence_rel := union_data(., id(..), id(..));
						// attribute<uint32>               Ordinal      := union_data(., const(0,..,uint32), const(1,..,uint32));
					// }
				// }
				
			}
		}

		unit<uint32> NS_stations
		: StorageName = "%ProjDir%/Data/Tarieven_NS/NS_stations.csv"
		, StorageType = "gdal.vect"
		, StorageReadOnly = "true"
		, URL = "https://data.ndovloket.nl/ns/ns-latest.zip"
		, Descr = "stations.dat downloaden, csv van maken, en headers toevoegen."
		{
			attribute<string> code  := trim(stations_code);
			attribute<string> label := trim(stations_naam);
			attribute<rdc>    geometry := rjoin(code, lowercase(Infrastructure/Read_NS_Stations_SHP/code), Infrastructure/Read_NS_Stations_SHP/geometry_rd);
			
			attribute<bool>   LigtInNL                  := IsDefined(point_in_polygon(geometry, /SourceData/RegioIndelingen/NL/geometry));
			attribute<bool>   StationNotInGTFSStops     := IsNull(invert(/SourceData/Infrastructure/GTFS/PublicTransportNet/Stops/NS_Stations_rel));
			
			unit<uint32> NL := select_with_attr_by_cond(., LigtInNL);
		}
	}
}