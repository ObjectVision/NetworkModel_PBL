container OVprijzen  
{
	unit<uint8> TariefTypeK : nrofrows = 2
	{
		attribute<string> name   : ['PerRit','Kilometertarief'];
		attribute<string> label  := name;
	}
	
	unit<uint32> Agencies          := Classifications/Agencies;
	unit<uint8>  Modes             := Classifications/GTFS_Modes/Selection;
	// unit<uint32> Provincies        := SourceData/RegioIndelingen/Provincie;
	unit<uint8>  Concessiegebieden := SourceData/RegioIndelingen/Concessiegebied;
	
	unit<uint8> FareTable := =ModelParameters/Advanced/PriceMethod_effective == 'DOVA' ? 'FareTable_DOVA' : 'FareTable_'+ModelParameters/Advanced/FareTable_year;
	
	unit<uint32> Read_DOVA_kmtarieven
	: StorageName = "%ProjDir%/data/DOVA_Overzicht km-tarieven 2013-2026_edit.xlsx"
	, StorageType = "gdal.vect"
	, StorageReadOnly = "true"
	, SqlString   = "SELECT * FROM kmtarief"
	{
		// attribute<string>       Mode            := ;
		// attribute<string>       Lijn            := Elements/Text[value(UInt32(ID(.))* nrAttr + 4, Elements)];
		attribute<Euro>         FixedPrice      := const(Read_DOVA_basistarieven/FixedPrice_param,.);
		attribute<Euro_km>      VariablePrice   := ='y'+ModelParameters/Advanced/DOVA_year+'[Euro_km]';
		// attribute<string>       Opmerking       := Elements/Text[value(UInt32(ID(.))* nrAttr + 7, Elements)];
		
		// attribute<Modes>             Mode_rel               := rlookup(Mode, Modes/name);
		// attribute<Agencies>          Agency_rel             := rlookup(lowercase(Vervoerder), Agencies/name);
		// attribute<Concessiegebieden> Concessiegebieden_rel  := rlookup(Concessiegebied, Concessiegebieden/name);
		
		// attribute<string>       Concessiegebied_str := AsItemName(Concessiegebied != '' ? ''+Concessiegebied : '');
		// attribute<string>       Lijn_str            := Lijn != '' ? '_'+Lijn : '';
		
		// attribute<string>       Mode_Agency_CG_Lijn_identifier := Mode +'_'+ lowercase(Vervoerder) +'_'+ Concessiegebied_str + Lijn_str;
		// attribute<string>       Mode_Agency_CG_identifier      := Mode +'_'+ lowercase(Vervoerder) +'_'+ Concessiegebied_str;
		// attribute<string>       Mode_Agency_identifier         := Mode +'_'+ lowercase(Vervoerder);
		// attribute<string>       label                                 := Mode_Agency_CG_Lijn_identifier;
	}
	
	unit<uint32> Read_DOVA_basistarieven
	: StorageName = "%ProjDir%/data/DOVA_Overzicht km-tarieven 2013-2026_edit.xlsx"
	, StorageType = "gdal.vect"
	, StorageReadOnly = "true"
	, SqlString   = "SELECT * FROM basistarief"
	{
		attribute<Euro>         FixedPrice       := ='y'+ModelParameters/Advanced/DOVA_year+'[Euro]';
		parameter<Euro>         FixedPrice_param := first(FixedPrice);
	}

	unit<uint8> ModeKlasse : NrOfRows = 3
	{
		attribute<string> name : ['BTM','Rail','Ferry'], Descr = "Mode-klassen voor DOVA-prijzen: BTM=bus/tram/metro, Rail=regionale trein, Ferry=veer. NS-trein loopt via het L-net (NS-tariefstructuur), niet via deze FareTable.";
		attribute<Euro_km> VariablePrice_landelijk := mean(Read_DOVA_kmtarieven_Priced/VariablePrice, Read_DOVA_kmtarieven_Priced/ModeKlasse_rel), Descr = "Landelijk gemiddeld km-tarief per mode-klasse (volgt het gekozen jaar); fallback voor concessies zonder DOVA-rij en voor het Buitenland-vangnet.";
	}

	// Eén canonieke DOVA-rij per (concessie, mode-klasse) (kolom use_for_price=1 in de xlsx).
	// Harmonisatie DOVA->shape-concessie via kolom Concessiegebied_model (byte-exact), mode-klasse via kolom Mode_klasse.
	unit<uint32> Read_DOVA_kmtarieven_Priced := select_with_attr_by_cond(Read_DOVA_kmtarieven, uint8(Read_DOVA_kmtarieven/use_for_price) > 0b)
	{
		attribute<string>       MC_CG_key     := Mode_klasse + '_' + AsItemName(Concessiegebied_model);
		attribute<ModeKlasse>   ModeKlasse_rel := rlookup(Mode_klasse, ModeKlasse/name);
	}

	// FareTable uit DOVA-overzicht, gekeyd op (concessie x mode-klasse); geselecteerd wanneer ModelParameters/Advanced/PriceMethod == 'DOVA'.
	// BTM (bus/tram/metro) krijgt het concessie-km-tarief; Rail (regionale trein) krijgt DOVA's aparte rail-km-tarief; Ferry idem waar beschikbaar.
	// Ontbrekende (concessie,klasse)-combinaties vallen terug op het BTM-tarief van dezelfde concessie (MakeDefined).
	unit<uint8> FareTable_DOVA_NL := combine_uint8(Concessiegebieden, ModeKlasse)
	{
		attribute<string>       CG_name                := Concessiegebieden/name[first_rel];
		attribute<string>       MC_name                := ModeKlasse/name[second_rel];
		attribute<string>       MC_CG_key              := MC_name + '_' + CG_name;
		attribute<Euro>         FixedPrice             := const(Read_DOVA_basistarieven/FixedPrice_param, .);
		attribute<Euro_km>      VariablePrice_specific := rjoin(MC_CG_key,      Read_DOVA_kmtarieven_Priced/MC_CG_key, Read_DOVA_kmtarieven_Priced/VariablePrice);
		attribute<Euro_km>      VariablePrice_BTM      := rjoin('BTM_'+CG_name, Read_DOVA_kmtarieven_Priced/MC_CG_key, Read_DOVA_kmtarieven_Priced/VariablePrice);
		// laatste fallback: landelijk klassegemiddelde, voor shape-concessies zonder DOVA-rij (bv. Stadsvervoer Lelystad in de 2023-shape).
		attribute<Euro_km>      VariablePrice          := MakeDefined(MakeDefined(VariablePrice_specific, VariablePrice_BTM), ModeKlasse/VariablePrice_landelijk[second_rel]);
	}

	// Vangnet voor legs buiten alle concessie-polygonen (buitenlandse trajectdelen De Lijn/DB/Eurobahn/NIAG en
	// eventuele rand-artefacten): 1 rij per mode-klasse, key '<klasse>_Buitenland' (zie MC_CG_key_DOVA in
	// OD_extra_attributen). km-tarief = landelijk DOVA-gemiddelde van de klasse (volgt het gekozen jaar),
	// opstap = landelijk basistarief. Zonder dit vangnet faalt Price_IntegrityCheck in DOVA-modus op die legs.
	unit<uint8> FareTable_DOVA := union_unit_uint8(FareTable_DOVA_NL, ModeKlasse)
	{
		attribute<string>       MC_CG_key              := union_data(., FareTable_DOVA_NL/MC_CG_key, ModeKlasse/name + '_Buitenland');
		attribute<Euro>         FixedPrice             := union_data(., FareTable_DOVA_NL/FixedPrice, const(Read_DOVA_basistarieven/FixedPrice_param, ModeKlasse));
		attribute<Euro_km>      VariablePrice          := union_data(., FareTable_DOVA_NL/VariablePrice, ModeKlasse/VariablePrice_landelijk);
		// dummy-identifiers voor compatibiliteit met FareTable_rel_initial/augmented in OD_extra_attributen (niet gebruikt in DOVA-modus).
		attribute<string>       Mode_Agency_CG_Lijn_identifier := MC_CG_key;
		attribute<string>       Mode_Agency_CG_identifier      := MC_CG_key;
		attribute<string>       Mode_Agency_identifier         := MC_CG_key;
		attribute<string>       label                          := MC_CG_key;
	}

