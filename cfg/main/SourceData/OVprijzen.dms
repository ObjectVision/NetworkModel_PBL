		attribute<string>       Mode            := Elements/Text[value(UInt32(ID(.))* nrAttr + 0, Elements)];
		attribute<string>       Vervoerder      := Elements/Text[value(UInt32(ID(.))* nrAttr + 1, Elements)], Descr = "/SourceData/Infrastructure/GTFS/LoadFeeds/ReadFSS/agency/Data/agency_name";
		attribute<string>       Concessiegebied := Elements/Text[value(UInt32(ID(.))* nrAttr + 3, Elements)];
		attribute<string>       Lijn            := Elements/Text[value(UInt32(ID(.))* nrAttr + 4, Elements)];
		attribute<Euro>         FixedPrice      := Elements/Text[value(UInt32(ID(.))* nrAttr + 5, Elements)][Euro];
		attribute<Euro_km>      VariablePrice   := Elements/Text[value(UInt32(ID(.))* nrAttr + 6, Elements)][Euro_km];
		attribute<string>       Opmerking       := Elements/Text[value(UInt32(ID(.))* nrAttr + 7, Elements)];
		
		attribute<Modes>             Mode_rel               := rlookup(Mode, Modes/name);
		attribute<Agencies>          Agency_rel             := rlookup(lowercase(Vervoerder), Agencies/name);
		attribute<Concessiegebieden> Concessiegebieden_rel  := rlookup(AsItemName(Concessiegebied), Concessiegebieden/name);
		
		attribute<string>       Concessiegebied_str := AsItemName(Concessiegebied != '' ? ''+Concessiegebied : '');
		attribute<string>       Lijn_str            := Lijn != '' ? '_'+Lijn : '';
		
		attribute<string>       Mode_Agency_CG_Lijn_identifier := Mode +'_'+ lowercase(Vervoerder) +'_'+ Concessiegebied_str + Lijn_str;
		attribute<string>       Mode_Agency_CG_identifier      := Mode +'_'+ lowercase(Vervoerder) +'_'+ Concessiegebied_str;
		attribute<string>       Mode_Agency_identifier         := Mode +'_'+ lowercase(Vervoerder);
		attribute<string>       label                          := Mode_Agency_CG_Lijn_identifier;

		parameter<uint32> nrAttr := 8;
	}

