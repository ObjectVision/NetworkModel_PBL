container NetworkModel : IntegrityCheck = "GeoDMSVersion() >= 17.0900" // format 17.1.2 -> 17.0102
{ 	
	//// GENEREER OV Resultaten: 
	// 1. Genereer de benodigde ontkoppelde OV-netwerk. Dit is onafhankelijk van orgs en dests -> MakeUnlinkedData/PublicTransportNet/Generate_PT
	// 2. Reload, i.e. Alt+R
	// 3. Genereer de output (i.e. csv's) voor alle blocken en tijdstippen, dus alle org-dests. -> /NetworkSetup/ConfigurationPerBlock/Generate_Output/OUTPUT_Generate_PublicTransport_fullOD_long_CSVFiles
	// 4. Reload, i.e. Alt+R
	// 5. Merge block/tijd csv's naar enkel tijd-csv's -> /NetworkSetup/ConfigurationPerBlock/MergeRegions/OUTPUT_Merge_PublicTransport_Regions_fullOD_long_CSVFiles
	// 6. Reload, i.e. Alt+R
	// 7. Merge tijd-csv's naar een enkel csv met alle resultaten in long-format -> /NetworkSetup/ConfigurationPerBlock/MergeTimes/OUTPUT_Merge_PublicTransport_Times_fullOD_long_CSVFiles

	container ChecksBeforeRunning
	{
		parameter<string> PT_CheckBlocks         := MakeUnlinkedData/PublicTransportNet/CheckEerstDezeIntegrityCheck_1;
		parameter<string> PT_CheckPrices         := MakeUnlinkedData/PublicTransportNet/CheckEerstDezeIntegrityCheck_2;
		parameter<string> PT_CheckPriceCoverage  := SourceData/Infrastructure/OVprijzen/PrijsDekking/Status_gated
													, Descr = "Goedkope voorcheck, te draaien VOOR de (uren durende) netwerkbouw en blokruns, bij elke nieuwe feed of nieuw prijsjaar: dekt de actieve prijstabel alle (mode,agency)-combinaties van de geladen GTFS-feed, en zijn alle tabelprijzen gevuld en plausibel? PT_CheckPrices blijft de sluitende check op OD-niveau (na netwerkbouw); diagnose bij FAIL daarvan: NetworkSetup/PublicTransport_Prep/Impl/OD_R/impl/Ongeprijsd/uniek.";
		parameter<string> Check_OriginBlocks      := ModelParameters/Advanced/NumberOfOrgBlocks * ModelParameters/Advanced/MaxOrgBlockSize >= #/NetworkSetup/Impl/OrgBlockSelections 
																												? 'PASS: block numbers and size are adequate.' 
																												: 'FAIL: you need more or larger blocks to accomodate all origins. It needs to be at least '+string(#/NetworkSetup/Impl/OrgBlockSelections )+' and now it is '+string(ModelParameters/Advanced/MaxOrgBlockSize)+' * '+string(ModelParameters/Advanced/NumberOfOrgBlocks)+' = '+string(uint64(ModelParameters/Advanced/MaxOrgBlockSize) * uint64(ModelParameters/Advanced/NumberOfOrgBlocks))+'';
	}

	container MakeUnlinkedData
	{
		container OSM
		{   
			parameter<String> Step1_Generate_roads_Final_Network             := 'Ready', ExplicitSuppliers = "SourceData/Infrastructure/OSM/Make_Final_Network";
			parameter<String> Export_Networks_toShapefile                    := 'Ready', ExplicitSuppliers = "SourceData/Infrastructure/OSM/OSM_Netwerken_Export/Generate";
		}
		
		container TomTom
		{
			parameter<String> GetFilesName_network                           := 'Ready', ExplicitSuppliers = "SourceData/Infrastructure/TomTom/impl/GetFileNames_Network/WriteFilesCSV";
			parameter<String> GetFilesName_profiles                          := 'Ready', ExplicitSuppliers = "SourceData/Infrastructure/TomTom/impl/GetFileNames_Speedprofiles/WriteFilesCSV";
			parameter<String> Generate                                       := 'Ready', ExplicitSuppliers = "SourceData/Infrastructure/TomTom/impl/Generate_FSS";
		} 
		
		container GTFS
		{
			parameter<String> Generate_GTFS                              := 'Ready', ExplicitSuppliers = "/SourceData/Infrastructure/GTFS/LoadFeeds/store";
			parameter<String> Export_OV_Knooppunten                      := 'Ready', ExplicitSuppliers = "/SourceData/Infrastructure/GTFS/OV_Knooppunten/Export_Knooppunten";
			parameter<String> Export_Reistijd_OV_Knooppunt_tif          := 'Ready', ExplicitSuppliers = "/SourceData/Infrastructure/GTFS/OV_Knooppunten/Bereikbaarheid_Auto/Reistijd";
		}
		
		container PublicTransportNet
		{
			parameter<string> CheckEerstDezeIntegrityCheck_1               := uint64(ModelParameters/Advanced/MaxStopBlockSize) * uint64(ModelParameters/Advanced/NumberOfStopBlocks) > uint64(#/NetworkSetup/PublicTransport_Prep/Impl/BlockSelections) 
																																	? 'PASS: block numbers and size are adequate. It needs to be at least '+string(#/NetworkSetup/PublicTransport_Prep/Impl/BlockSelections)+' and now it is '+string(ModelParameters/Advanced/MaxStopBlockSize)+' * '+string(ModelParameters/Advanced/NumberOfStopBlocks)+' = '+string(uint64(ModelParameters/Advanced/MaxStopBlockSize) * uint64(ModelParameters/Advanced/NumberOfStopBlocks)) 
																																	: 'FAIL: you need more or larger blocks to accomodate all stops. It needs to be at least '+string(#/NetworkSetup/PublicTransport_Prep/Impl/BlockSelections)+' and now it is '+string(ModelParameters/Advanced/MaxStopBlockSize)+' * '+string(ModelParameters/Advanced/NumberOfStopBlocks)+' = '+string(uint64(ModelParameters/Advanced/MaxStopBlockSize) * uint64(ModelParameters/Advanced/NumberOfStopBlocks))+''
																																, Descr = "Is the number of stops smaller or equal to the number of blocks times the size of the blocks. If this fails, check the size";
			parameter<string> CheckEerstDezeIntegrityCheck_2               := all(NetworkSetup/PublicTransport_Prep/Impl/OD_R/Impl/Price_IntegrityCheck) && all(/NetworkSetup/PublicTransport_Prep/Impl/OD_L/NS_Station_Price_IntegrityCheck)  ? 'PASS: all links have a valid price (or no prices are needed)' : 'FAIL: you need to check the prices (or turn of prices)', Descr = "Check whether all links have a valid price (a matching FareTable row that actually contains prices), if prices are necessary (i.e. given model parameters). If this fails: see NetworkSetup/PublicTransport_Prep/Impl/OD_R/impl/Ongeprijsd/uniek for the uncovered (mode,agency,concession,line) combinations, and run /ChecksBeforeRunning/PT_CheckPriceCoverage as cheap pre-check before rebuilding.";
			parameter<String> Generate_PT                                  := 'Ready', ExplicitSuppliers = "/NetworkSetup/PublicTransport_Prep/x/Write_Result";
		}
		
		container ExportNetworks
		{
			parameter<string> Car_TomTom  := 'Ready', ExplicitSuppliers = "/SourceData/Infrastructure/TomTom/Roads_selection/Export/Network"; 
			parameter<string> Cycling_OSM := 'Ready', ExplicitSuppliers = "/SourceData/Infrastructure/OSM/OSM_Netwerken_Export/Cycling/Generate"; 
			parameter<string> Walking_OSM := 'Ready', ExplicitSuppliers = "/SourceData/Infrastructure/OSM/OSM_Netwerken_Export/Walking/Generate"; 
			parameter<string> Car_OSM     := 'Ready', ExplicitSuppliers = "/SourceData/Infrastructure/OSM/OSM_Netwerken_Export/Car/Generate"; 
			
		}
	}
	
	#include<ModelParameters.dms>
	#include<units.dms>
	
	container geometries : using = "units"
	{
		#include <ngr_layer.dms>
		#include <ngr_layer_lea.dms>

		unit<dpoint> rdc_base : SpatialReference = "EPSG:28992", DialogData = "ngr_layer";
		unit<dpoint> rdc      := range(rdc_base, point_xy(0d, 300000d), point_xy(280000d, 625000d)) //heel NL
		{
			parameter<float32> PenWorldWidth := 1f, DialogData = "PenWorldWidth";
		}
		unit<ipoint> rdc_cm   := gridset(rdc, point_xy(0.01,0.01), point_xy(0.0, 0.0), ipoint);
		unit<ipoint> rdc_mm   := gridset(rdc, point_xy(0.001,0.001), point_xy(0.0, 0.0), ipoint);

		// unit<dpoint> rdc_f64_base : SpatialReference = "EPSG:28992";
		// unit<dpoint> rdc_f64      := range(rdc_f64_base, point_xy(0d, 300000d), point_xy(280000d, 625000d))
		// , Descr = "float64-variant van rdc, uitsluitend voor geos_*/bg_*-operaties die dpoint-coordinaten vereisen. Resultaat daarna terugcasten naar rdc: float32 is in de rest van het model ruim voldoende, en de bestaande fss/mmd-caches (Final_Network, GTFS-store, PT-netwerk, TomTom) zijn in fpoint opgeslagen en zouden bij een dpoint-rdc allemaal opnieuw gegenereerd moeten worden.";
		
		unit<dpoint> wgs84_base       : SpatialReference = "EPSG:4326";
		unit<fpoint> LambertEA_base   : SpatialReference = "EPSG:3035", DialogData = "ngr_layer_lea";
		unit<fpoint> LambertEA        := range(LambertEA_base, point_xy(2500000f, 1300000f), point_xy(4900000f, 4300000f));
		unit<fpoint> WebMercator_base : SpatialReference = "EPSG:3857";
		
		unit<uint32> selection_polygon : nrofrows = 1, Using = "units"
		{
			parameter<rdc> top_left     := point_xy(x_min - 5000[m_f64], y_max + 5000[m_f64], rdc); //XY
			parameter<rdc> top_right    := point_xy(x_max + 5000[m_f64], y_max + 5000[m_f64], rdc);
			parameter<rdc> bottom_left  := point_xy(x_min - 5000[m_f64], y_min - 5000[m_f64], rdc);
			parameter<rdc> bottom_right := point_xy(x_max + 5000[m_f64], y_min - 5000[m_f64], rdc);
			
			unit<uint32> point_set : nrofrows = 5
			{
				attribute<rdc>  point        := union_data(., top_left, top_right, bottom_right, bottom_left, top_left);
				attribute<..>   sequence_rel := const(0, .);
				attribute<.>    ordinal      := id(.);
			}
			
			attribute<rdc> polygon (poly)      := points2sequence(point_set/point, point_set/sequence_rel, point_set/ordinal);
		}
		
		unit<uint32> Gridsizes : nrofrows = 7
		{
			attribute<m>      size : [25, 100, 500, 1000, 5000, 10000, 50000];
			attribute<string> name := 'size_'+string(size)+'m';
		}

		unit<spoint> rdc_25m    := perGridsize/size_25m/domain;
		unit<spoint> rdc_100m   := perGridsize/size_100m/domain;
		unit<spoint> rdc_500m   := perGridsize/size_500m/domain;
		unit<spoint> rdc_1000m  := perGridsize/size_1000m/domain;
		unit<spoint> rdc_5000m  := perGridsize/size_5000m/domain;
		unit<spoint> rdc_10000m := perGridsize/size_10000m/domain;
		unit<spoint> rdc_50000m := perGridsize/size_50000m/domain;
	
		parameter<m_f64> x_min := 0[m_f64];
		parameter<m_f64> x_max := 280000[m_f64];
		parameter<m_f64> y_min := 300000[m_f64];
		parameter<m_f64> y_max := 625000[m_f64];
		
		// test study area
		// parameter<m> x_min := 58986[m];
		// parameter<m> x_max := 74522[m];
		// parameter<m> y_min := 414166[m];
		// parameter<m> y_max := 423385[m];
		
		container perGridsize :=
			for_each_ne(
				Gridsizes/name
				, 'Create_GridDomain_T('+string(Gridsizes/size)+'[m_f64])'
			);
		
		Template Create_GridDomain_T
		{
			parameter<m_f64> gridsize;
			
			parameter<int16> nr_cols := int16((x_max - x_min) / gridsize);
			parameter<int16> nr_rows := int16((y_max - y_min) / gridsize);
			
			unit<spoint> domain :=
				range(
					 gridset(
						 rdc
						,point_xy(gridsize, -gridsize, rdc)
						,point_xy(x_min, y_max, rdc)
						,spoint
					)
					,point_xy(0s, 0s)
					,point_xy(nr_cols, nr_rows)
				)
			,	DialogData = "rdc"
			{
				parameter<m_f64>                    gridsize        := ../gridsize;
				parameter<int16>                nr_cols         := ../nr_cols;
				attribute<rdc>                  point           := mapping(., rdc) + point_xy(-0.5d * gridsize, 0.5d * gridsize, rdc);
				attribute<rdc>                  geometry        := mapping(., rdc) + point_xy(-0.5d * gridsize, 0.5d * gridsize, rdc);
				attribute<uint32>               id_rel          := value(uint32(pointrow(id(.))) * uint32(nr_cols) + uint32(pointcol(id(.))), id_key);
				unit<uint32>  id_key := range(uint32, 0, #domain);
				
				attribute<rdc_100m>             rdc_100m_rel    := mapping(., rdc_100m);
				attribute<rdc_500m>             rdc_500m_rel    := mapping(., rdc_500m);
				
				parameter<ha>                   NrHaPerCell     := convert(gridsize * gridsize, ha);
				parameter<km2>                  NrKm2PerCell    := NrHaPerCell[km2];
				attribute<bool>                 IsNederland     := IsDefined(point_in_polygon(geometry, /SourceData/RegioIndelingen/NL/Nederland_10kbuffer));
			}
			
			unit<uint32> points := select_with_org_rel(domain/IsNederland)
			{
				attribute<rdc>                  geometry  := org_rel -> geometry;
				attribute<float64>              x         := PointCol(geometry);
				attribute<float64>              y         := PointRow(geometry);
				attribute<domain>               grid_rel  := geometry[domain];	
				attribute<rdc_100m>             rdc_100m_rel  := geometry[rdc_100m];	
			}
		}

		unit<uint8> Matrix : nrofrows = 23
		{
			attribute<m>      Size : [ 0, 17, 25, 50, 100, 150, 200, 300, 500, 625, 1000, 1250, 1500, 2000, 2250, 2500, 3250, 5000, 5250, 10000, 10250, 20000, 20250 ];
			attribute<string> name := 'pot'+string(size)+'m';
		}
		
		container Distmatrices_25m  := for_each_nex(Matrix/name, 'Distmatrices/Impl_25m/'+Matrix/name+'/PotRange', spoint);
		container Distmatrices_100m := for_each_nex(Matrix/name, 'Distmatrices/Impl_100m/'+Matrix/name+'/PotRange', spoint);
		
		container Distmatrices 
		{
			unit<uint32> Dist2Range;
			
			template potrange
			{
				parameter<m>       gridgrootte;
				parameter<m>       afkapstraal;
				parameter<float32> straal       := afkapstraal / gridgrootte;
				parameter<float32> oppervlakte  := pi()[float32] * straal^2f;
				
				unit<spoint> tmpRange := range(spoint, point_yx(-int16(straal), -int16(straal)), point_yx(int16(straal) + 1s, int16(straal) + 1s));
				unit<spoint> potRange := tmpRange
				{
					attribute<Dist2Range> distMatr          := dist2(point_yx(0s, 0s, tmpRange), Dist2Range);
					attribute<float32>    dist              := sqrt(float32(distMatr));
					attribute<float32>    dist_scaled       := dist / straal;
					
					attribute<float32>    rev_dist          := max_elem(straal - dist, 0f);
					parameter<float32>    rev_dist_max      := max(rev_dist);
					attribute<float32>    rev_dist_scaled   := rev_dist / rev_dist_max;
					attribute<float32>    AbsWeight         := distMatr[float32] <= (straal * straal) 
																? distMatr[float32] != 0f 
																	? 1f / (distMatr[float32] ^ 2f) 
																	: 1f
																: 0f;
					attribute<float32>    AbsWeight_ln      := distMatr[float32] <= (straal * straal) 
																? distMatr[float32] != 0f 
																	? 1f / (distMatr[float32] / straal) 
																	: 1f 
																: 0f;
					attribute<float32>    RelWeight         := scalesum(     AbsWeight , 1.0f);
					attribute<float32>    RelWeightSqrt     := scalesum(Sqrt(AbsWeight), 1.0f);
					attribute<float32>    Flat2             := float32(distMatr <= uint32(straal * straal));
					attribute<float32>    Flat_Visualisatie := dist <= 1.5f ? 1f : 0f;
					attribute<float32>    neighbourhood     := distMatr > 0 ? 1f : 0f;
					parameter<float32>    oppervlakte       := sum(Flat2);
					attribute<float32>    binair            := distMatr <= 100 ? 1f : 0f;
				}
			}
			
			container Impl_25m  := for_each_ne(Matrix/name, 'potrange(25[m],'+string(Matrix/size)+'[m])');
			container Impl_100m := for_each_ne(Matrix/name, 'potrange(100[m],'+string(Matrix/size)+'[m])');
		}	
	}
	
	#include<Classifications.dms>
	#include<SourceData.dms>
	#include<NetworkSetup.dms>
	#include<Templates.dms>
	#include<PostAnalysis.dms>
	// #include<RegressieTest.dms>
	#include<ExportSettings.dms>
	#include<ConfigSettings.dms>
}